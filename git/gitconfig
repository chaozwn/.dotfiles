# Managed by ~/.dotfiles (dotbot → ~/.gitconfig).
# Per-machine secrets or overrides: ~/.gitconfig.local (optional; Git skips if missing).
# Requires: git, git-lfs (filters below), delta (core.pager / interactive.diffFilter), nvim (core.editor).

[safe]
	directory = /opt/homebrew
	directory = /opt/homebrew/Library/Taps/homebrew/homebrew-core/
	directory = /opt/homebrew/Library/Taps/homebrew/homebrew-cask/
	directory = /opt/homebrew/Library/Taps/homebrew/homebrew-services/
	# Intel Mac Homebrew — harmless on Linux / Apple Silicon
	directory = /usr/local/Homebrew
	directory = /usr/local/Library/Taps/homebrew/homebrew-core/
	directory = /usr/local/Library/Taps/homebrew/homebrew-cask/
	directory = /usr/local/Library/Taps/homebrew/homebrew-services/

[user]
	name = zhao_wei_nan
	email = 326747337@qq.com

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[core]
	editor = nvim
	pager = delta
  autocrlf = input
	# Treat whitespace issues as errors
	whitespace = trailing-space,space-before-tab

[interactive]
	diffFilter = delta --color-only --show-syntax-themes --features=interactive

[delta "decorations"]
	keep-plus-minus-markers = false
	commit-decoration-style = bold yellow box ul
	file-style = bold yellow ul
	file-decoration-style = none

[delta]
	side-by-side = true
	line-numbers = true
	minus-style                   = syntax "#3f2d3d"
	minus-non-emph-style          = syntax "#3f2d3d"
	minus-emph-style              = syntax "#763842"
	minus-empty-line-marker-style = syntax "#3f2d3d"
	line-numbers-minus-style      = "#914c54"
	plus-style                    = syntax "#283b4d"
	plus-non-emph-style           = syntax "#283b4d"
	plus-emph-style               = syntax "#316172"
	plus-empty-line-marker-style  = syntax "#283b4d"
	line-numbers-plus-style       = "#449dab"
	line-numbers-zero-style       = "#3b4261"

[diff]
	algorithm = histogram
	colorMoved = default
	tool = nvim_difftool
	# Better submodule diffs
	submodule = log

[difftool "nvim_difftool"]
  cmd = nvim -c \"packadd nvim.difftool\" -c \"DiffTool $LOCAL $REMOTE\"

[pull]
	rebase = true

[merge]
	conflictStyle = zdiff3
  tool = nvimdiff

[rerere]
	enabled = true

[rebase]
	updateRefs = true

[color]
  ui = auto

[help]
	autocorrect = prompt

[log]
	date = auto:human

[alias]
	; https://stackoverflow.com/questions/1057564/pretty-git-branch-graphs
	lg1 = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)' --all
	lg2 = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(auto)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'
	lg = lg1

	; How to stash changes while keeping the changes in the working directory? (Git)
	; https://stackoverflow.com/a/60557208/1336788
	stash-keep = "!f() { git stash store --message \"$(date +'%Y-%m-%d %H:%M:%S')\" \"$1\"; }; f $(git stash create)"

	st = status -sb
	co = checkout
	c = commit --short
	ci = commit --short
	p = push
	l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --decorate --date=short --color --decorate

[commit]
	verbose = true

[init]
	defaultBranch = main

[push]
	default = upstream

[http]
	postBuffer = 524288000
	lowSpeedLimit = 0
	lowSpeedTime = 999999

[include]
	path = ~/.gitconfig.local
