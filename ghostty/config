# 配置文档: https://ghostty.org/docs/config/reference
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 15

# 终端环境变量
term = "xterm-256color"

# 窗口设置
window-padding-x = 2
window-padding-y = 2
window-decoration = auto
window-vsync = true

# 不移除掉圆角
macos-titlebar-style = hidden

# 光标设置
cursor-style = "block"
cursor-style-blink = true

# 主题设置（可选，取消注释以启用）
theme = "TokyoNight Moon"

# macOS 特定设置
macos-option-as-alt = true

# 添加shader
custom-shader = "~/.config/ghostty/ghostty-shader-playground/public/shaders/cursor_smear.glsl"

# 复制粘贴（Linux 上默认是 Ctrl+Shift+C / Ctrl+Shift+V；Ctrl+C 在 shell 里是“中断”）
# performable：仅在有选区时才消耗 Ctrl+C 为复制，无选区时仍为中断( SIGINT )
keybind = performable:ctrl+c=copy_to_clipboard:mixed
keybind = ctrl+v=paste_from_clipboard

# 右键：有选区则复制，否则粘贴（比仅弹出菜单更直观）
right-click-action = copy-or-paste

# 选中文本时同步到系统剪贴板（与 X11/Wayland 其它应用用 Ctrl+V 互通更稳）
copy-on-select = clipboard

